# Claude Console API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override API base URL
# ANTHROPIC_API_BASE=https://api.anthropic.com

# OpenAI API (for --provider openai)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama local inference (for --provider ollama)
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_API_KEY=ollama

# Pilot script defaults
# PILOT_MODEL=qwen2.5-coder:7b
# PILOT_CASE=premise_trap_is_even_001
